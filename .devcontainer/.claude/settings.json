{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "allow": [
      "Agent",
      "AskUserQuestion",
      "Bash",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Edit",
      "EnterPlanMode",
      "EnterWorktree",
      "ExitPlanMode",
      "ExitWorktree",
      "Glob",
      "Grep",
      "ListMcpResourcesTool",
      "LSP",
      "Read",
      "ReadMcpResourceTool",
      "SendMessage",
      "Skill",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "ToolSearch",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(cat ~/.aws:*)",
      "Bash(cat ~/.gcp:*)",
      "Bash(cat ~/.ssh:*)",
      "Bash(curl:*)",
      "Bash(git branch -D:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git stash drop:*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(wget:*)",
      "Edit(~/.aws/**)",
      "Edit(~/.gcp/**)",
      "Edit(~/.ssh/**)",
      "MultiEdit(~/.aws/**)",
      "MultiEdit(~/.gcp/**)",
      "MultiEdit(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gcp/**)",
      "Read(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gcp/**)",
      "Write(~/.ssh/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "cat | bash ~/.claude/statusline.sh"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for p in /dev/pts/[0-9]*; do printf '\\007' > \"$p\" 2>/dev/null; done"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for p in /dev/pts/[0-9]*; do printf '\\007' > \"$p\" 2>/dev/null; done"
          }
        ]
      }
    ]
  }
}
