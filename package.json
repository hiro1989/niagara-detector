{
  "name": "niagara-detector",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "run-s --continue-on-error lint:* lint-dry:tsc",
    "lint-dry": "run-s lint-dry:format lint-dry:oxlint lint-dry:eslint lint-dry:tsc",
    "lint-dry:format": "oxfmt --check",
    "lint-dry:oxlint": "oxlint --max-warnings=0 .",
    "lint-dry:tsc": "tsc --noEmit --pretty false",
    "lint:format": "oxfmt",
    "lint:oxlint": "oxlint --format unix . --max-warnings=0 --fix",
    "start": "tsx src/index.ts",
    "test": "vitest run --no-color --reporter=dot --silent=passed-only",
    "test-watch": "vitest --changed --root . --dir ."
  },
  "dependencies": {
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.x",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.40.0",
    "oxlint": "1.55.0",
    "oxlint-tsgolint": "0.16.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
